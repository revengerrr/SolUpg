# Base URL of the SolUPG API gateway.
SOLUPG_BASE_URL=http://localhost:3002

# API key issued by POST /v1/merchants/register.
# Get one by running the simple-payment example first, or by curling
# /v1/merchants/register against your local stack.
SOLUPG_API_KEY=REPLACE_WITH_YOUR_API_KEY

# Wallet that should receive payments scanned from QR codes.
# This is the merchant address. Replace with your real Solana wallet.
MERCHANT_WALLET=REPLACE_WITH_YOUR_WALLET_ADDRESS

# Optional SPL token mint to receive payments in.
# Leave blank for native SOL transfers.
# Devnet USDC mint: 4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
SPL_TOKEN_MINT=

# Local port the demo server listens on.
PORT=4000
