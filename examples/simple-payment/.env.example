# Base URL of the SolUPG API gateway.
# Default for local Docker Compose stack: http://localhost:3002
SOLUPG_BASE_URL=http://localhost:3002

# API key issued by POST /v1/merchants/register.
# Leave blank on first run: the example will register a new merchant and print one.
SOLUPG_API_KEY=

# Wallet address that will receive payments in this example.
# Replace with your real Solana wallet (base58, no quotes).
MERCHANT_WALLET=REPLACE_WITH_YOUR_WALLET_ADDRESS

# Wallet address of the payer for the demo payment intent.
# On devnet you can use any funded test wallet.
PAYER_WALLET=REPLACE_WITH_A_PAYER_WALLET_ADDRESS
